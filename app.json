{
  "expo": {
    "name": "TownTrip Trail Logger",
    "slug": "towntrip-trail-logger",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "towntriptraillogger",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.babakwe.towntrip.traillogger",
      "infoPlist": {
        "NSLocationAlwaysAndWhenInUseUsageDescription": "TownTrip needs location access to record your trail walks, including when the app is in the background.",
        "NSLocationWhenInUseUsageDescription": "TownTrip needs location access to record your trail walks.",
        "NSLocationAlwaysUsageDescription": "TownTrip needs background location access to record your trail walks.",
        "UIBackgroundModes": [
          "location",
          "fetch",
          "location",
          "fetch"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/adaptive-icon.png"
      },
      "package": "com.babakwe.towntrip.traillogger",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "TownTrip needs location to record your trail walks in the background.",
          "isIosBackgroundLocationEnabled": true
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "react-native-ble-plx"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d53615e1-712e-4039-9c62-aab4baa5b1e3"
      }
    }
  }
}
